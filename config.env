# Coding Agent default configuration.
# These are overridable by Jenkins parameters and environment variables.

BITBUCKET_URL=https://bitbucket.tc.lenovo.com
JIRA_URL=https://jira.tc.lenovo.com
SONARQUBE_URL=https://sonarqube.tc.lenovo.com

BOT_SERVICE_ACCOUNT=${BOT_SERVICE_ACCOUNT:-dsoagcicd}
BITBUCKET_USER=${BITBUCKET_USER:-${BOT_SERVICE_ACCOUNT}}

CURSOR_COMMONS_REPO=https://bitbucket.tc.lenovo.com/scm/cswtool/cursor-commons.git
CURSOR_COMMONS_DIR=/workspace/cursor-commons

MODEL_SERVER_PROVIDER=vllm
MODEL_NAME=Qwen3.6-27B
MODEL_SERVER_MODEL_ID=QuantTrio/Qwen3.6-27B-AWQ
MODEL_SERVER_BASE_URL=http://localhost:8000/v1
MODEL_SERVER_MAX_MODEL_LEN=65536

AGENT_HARNESS=${AGENT_HARNESS:-claude}

# Branch prefix for agent-created branches. Full name: agent/YYYYMMDD-<goal-slug>
AGENT_BRANCH_PREFIX=agent

GIT_AUTHOR_NAME=${GIT_AUTHOR_NAME:-${BOT_SERVICE_ACCOUNT}}
GIT_AUTHOR_EMAIL=dsoagcicd@lenovo.com
